п»ҝ# Database
# Local: use SQLite (trocar schema.prisma provider para "sqlite")
# DATABASE_URL="file:./dev.db"
# Production: use PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/faciliauto_mvp"

# =============================================================================
# REDIS - Cache e Rate Limiting DistribuГӯdo рҹ”„
# =============================================================================

# Redis URL para rate limiting distribuГӯdo e cache
# Formato: redis://host:port ou redis://username:password@host:port
# Se nГЈo configurado, usa in-memory (nГЈo recomendado para mГәltiplas instГўncias)
REDIS_URL="redis://localhost:6379"

# TTL para chaves de rate limiting no Redis (segundos)
REDIS_RATE_LIMIT_TTL="60"

# =============================================================================
# RATE LIMITING - Controle de RequisiГ§Гөes рҹӣЎпёҸ
# =============================================================================

# MГЎximo de requisiГ§Гөes permitidas por janela de tempo
RATE_LIMIT_MAX_REQUESTS="10"

# DuraГ§ГЈo da janela de rate limiting em milissegundos (60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS="60000"

# Exemplo: 10 requisiГ§Гөes por minuto = 10 msgs/min por usuГЎrio

# =============================================================================
# LLM PROVIDERS - Sistema com Fallback AutomГғВЎtico Г°ЕёВӨвҖ“
# =============================================================================

# OpenAI - LLM PrimГғВЎrio + Embeddings PrimГғВЎrios Г°ЕёВ§В 
# Obtenha sua chave em: https://platform.openai.com/api-keys
# LLM: gpt-4o-mini ($0.15 input, $0.60 output per 1M tokens)
# Embeddings: text-embedding-3-small (1536 dim, $0.02/1M tokens, MTEB 62.3)
OPENAI_API_KEY="sk-..."

# Groq - LLM Fallback ГўЕЎВЎ
# Obtenha sua chave em: https://console.groq.com/keys
# Modelo: llama-3.1-8b-instant ($0.05 input, $0.08 output per 1M tokens)
# Tier gratuito: 30 req/min, 14.4k tokens/min
# Usado automaticamente se OpenAI falhar
GROQ_API_KEY="gsk-..."

# Cohere - Embeddings Fallback Г°ЕёЕ’Вҗ
# Obtenha sua chave em: https://dashboard.cohere.com/api-keys
# Modelo: embed-multilingual-v3.0 (1024ГўвҖ вҖҷ1536 dim, $0.01/1M tokens)
# Excelente para portuguГғВӘs, usado se OpenAI embeddings falhar
# Tier gratuito: 100 chamadas/minuto
COHERE_API_KEY="..."

# Meta Cloud API (WhatsApp Business API Oficial) Г°ЕёвҖңВұ
# Obtenha em: https://developers.facebook.com/
# Veja: META_CLOUD_API_SETUP.md para instruГғВ§ГғВөes completas
META_WHATSAPP_TOKEN="seu_token_aqui"
META_WHATSAPP_PHONE_NUMBER_ID="seu_phone_number_id_aqui"
META_WHATSAPP_BUSINESS_ACCOUNT_ID="seu_business_account_id_aqui"
META_APP_SECRET="seu_meta_app_secret_aqui"
META_WEBHOOK_VERIFY_TOKEN="faciliauto_webhook_2025"

# Evolution API (Gateway alternativo do WhatsApp)
# Quando EVOLUTION_API_URL e EVOLUTION_API_KEY estГғВЈo definidos,
# o sistema usa Evolution automaticamente no WhatsAppServiceFactory.
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="carinsight_secret_key_123"
EVOLUTION_INSTANCE_NAME="carinsight"

# WhatsApp (legado)
WHATSAPP_NAME="FaciliAuto"

# CRM Webhook (opcional)
CRM_WEBHOOK_URL=""

# =============================================================================
# SALES TEAM - NotificaГғВ§ГғВЈo de Leads Г°ЕёвҖңЕҫ
# =============================================================================

# NГғВәmero do vendedor que receberГғВЎ os leads quentes via WhatsApp
# Formato: cГғВіdigo do paГғВӯs + DDD + nГғВәmero (sem espaГғВ§os ou caracteres especiais)
# Exemplo: 5511949105033
SALES_PHONE_NUMBER="5511916366717"

# Environment
NODE_ENV="development"
PORT=3000

# Admin Seed Secret (para endpoint /admin/seed-robustcar)
# Use um valor forte e ГғВәnico em produГғВ§ГғВЈo!
SEED_SECRET="change-me-in-production-use-strong-secret"

# Endpoint de teste de envio via /webhooks/whatsapp/test (desabilitado por padrГЈo)
ENABLE_WEBHOOK_TEST_ENDPOINT="false"

# =============================================================================
# FEATURE FLAGS Г°ЕёЕЎВ©
# =============================================================================

# Sistema Conversacional (Natural Language) vs Quiz Estruturado
# true: Usa VehicleExpertAgent para conversa natural
# false: Usa QuizAgent estruturado (legado)
ENABLE_CONVERSATIONAL_MODE="false"

# Rollout gradual do modo conversacional (0-100)
# Define % de usuГғВЎrios que usarГғВЈo o novo sistema
# Exemplo: 10 = 10% dos usuГғВЎrios usam conversacional, 90% usam quiz
CONVERSATIONAL_ROLLOUT_PERCENTAGE="0"

# =============================================================================
# AUDIO TRANSCRIPTION Г°ЕёЕҪВӨ
# =============================================================================

# Habilita transcriГғВ§ГғВЈo de mensagens de ГғВЎudio usando Groq Whisper
# true: Processa mensagens de ГғВЎudio e transcreve para texto
# false: Responde que ГғВЎudio nГғВЈo ГғВ© suportado
# Requer: GROQ_API_KEY configurada
ENABLE_AUDIO_TRANSCRIPTION="true"

# DuraГғВ§ГғВЈo mГғВЎxima de ГғВЎudio em segundos (default: 120 = 2 minutos)
# ГғВҒudios maiores serГғВЈo rejeitados com mensagem de erro

# =============================================================================
# OBSERVABILITY (LangSmith) Г°ЕёвҖўВөГҜВёВҸ
# =============================================================================

# Habilita tracing do LangChain/LangSmith
# true: Envia traces para o LangSmith
# false: Desabilita tracing
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="<sua-chave-aqui>"
LANGCHAIN_PROJECT="carinsight-prod"

